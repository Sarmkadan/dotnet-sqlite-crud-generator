{
  "$schema": "https://json.schemastore.org/appsettings.json",
  "Database": {
    "FilePath": "crudgenerator.db",
    "ConnectionTimeout": 30,
    "AutoCreateDatabase": true,
    "EnableLogging": false,
    "JournalMode": "Wal",
    "SynchronousMode": "Normal",
    "MaxPoolSize": 10,
    "MinPoolSize": 1,
    "IdleTimeoutSeconds": 300
  },
  "ConnectionPool": {
    "MinPoolSize": 1,
    "MaxPoolSize": 10,
    "IdleTimeoutSeconds": 300,
    "AcquireTimeoutSeconds": 30,
    "CleanupIntervalSeconds": 60,
    "EnableDiagnostics": false
  },
  "Cache": {
    "Enabled": true,
    "MaxSizeBytes": 10000000,
    "DefaultTTL": 1800,
    "CleanupIntervalSeconds": 300
  },
  "EventBus": {
    "Enabled": true,
    "MaxEventHistory": 1000,
    "PersistEvents": false,
    "EventStoragePath": "./eventstore"
  },
  "HttpClient": {
    "ConnectionLimit": 10,
    "DefaultTimeout": 30,
    "MaxRetries": 3,
    "RetryDelayMs": 1000
  },
  "Webhook": {
    "Enabled": true,
    "MaxRetries": 3,
    "RetryDelayMs": 5000,
    "MaxDeliveryHistorySize": 1000,
    "SigningSecret": "your-webhook-signing-secret"
  },
  "BackgroundWorker": {
    "Enabled": true,
    "WorkerCount": 2,
    "MaxQueueSize": 1000,
    "TaskTimeoutSeconds": 300,
    "MaxRetries": 3
  },
  "Migration": {
    "MigrationsPath": "./migrations",
    "BackupPath": "./backups",
    "CreateBackupBeforeMigration": true,
    "VerifyAfterMigration": true
  },
  "Validation": {
    "ValidateOnCreate": true,
    "ValidateOnUpdate": true,
    "MaxValidationErrors": 10,
    "ThrowOnValidationError": true
  },
  "Security": {
    "EncryptConnectionString": false,
    "RequireHttps": false,
    "AllowCors": [],
    "MaxRequestSize": 10485760
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    },
    "Console": {
      "IncludeScopes": false,
      "TimestampFormat": "yyyy-MM-dd HH:mm:ss"
    }
  }
}
